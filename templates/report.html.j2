<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的开发者人格 - {{ period_start }} 至 {{ period_end }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      color: #e2e8f0;
      min-height: 100vh;
      padding: 24px;
    }
    .container { max-width: 960px; margin: 0 auto; }
    h1 { text-align: center; margin-bottom: 8px; font-size: 24px; }
    .period { text-align: center; opacity: 0.6; margin-bottom: 32px; font-size: 14px; }
    .persona-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 24px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .persona-name {
      font-size: 48px;
      text-align: center;
      margin-bottom: 8px;
    }
    .persona-desc {
      text-align: center;
      font-size: 18px;
      opacity: 0.8;
      margin-bottom: 24px;
    }
    .chart-container {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 24px;
    }
    .chart-title {
      font-size: 16px;
      margin-bottom: 16px;
      opacity: 0.8;
    }
    #chart { width: 100%; height: 400px; }
    .category-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }
    .category-item {
      background: rgba(255, 255, 255, 0.05);
      padding: 16px;
      border-radius: 8px;
      border-left: 4px solid var(--color);
    }
    .category-name { font-size: 14px; opacity: 0.7; margin-bottom: 4px; }
    .category-value { font-size: 20px; font-weight: bold; }
    .category-pct { font-size: 12px; opacity: 0.6; margin-top: 4px; }
    .insights {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 24px;
    }
    .insight-item {
      padding: 12px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 15px;
    }
    .insight-item:last-child { border-bottom: none; }
    .insight-icon { margin-right: 8px; }
    .disclaimer {
      text-align: center;
      font-size: 12px;
      opacity: 0.5;
      margin-top: 32px;
    }
    .share-section {
      text-align: center;
      margin: 24px 0;
    }
    .share-btn {
      background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-size: 15px;
      cursor: pointer;
      transition: transform 0.1s;
    }
    .share-btn:hover { transform: translateY(-1px); }
    .share-btn:active { transform: translateY(0); }
    #share-canvas { display: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>🏷️ 我的开发者人格</h1>
    <p class="period">{{ period_start }} ~ {{ period_end }} · 共 {{ total_human }}</p>

    <div class="persona-card">
      <div class="persona-name">{{ persona }}</div>
      <div class="persona-desc">{{ persona_description }}</div>
    </div>

    <div class="chart-container">
      <div class="chart-title">📊 时间分布</div>
      <div id="chart"></div>
    </div>

    {% if daily_chart_data %}
    <div class="chart-container">
      <div class="chart-title">📅 每日趋势（分钟）</div>
      <div id="daily-chart" style="width: 100%; height: 320px;"></div>
    </div>
    {% endif %}

    <div class="chart-container">
      <div class="chart-title">📈 各类别详情</div>
      <div class="category-list">
        {% for cat in category_details %}
        <div class="category-item" style="--color: {{ cat.color }}">
          <div class="category-name">{{ cat.icon }} {{ cat.name }}</div>
          <div class="category-value">{{ cat.duration_human }}</div>
          <div class="category-pct">{{ cat.pct }}%</div>
        </div>
        {% endfor %}
      </div>
    </div>

    {% if insights %}
    <div class="insights">
      <div class="chart-title">💡 你可能不知道的事</div>
      {% for insight in insights %}
      <div class="insight-item">
        <span class="insight-icon">•</span>{{ insight }}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <p class="disclaimer">基于浏览器历史和 Git 活动估算 · 完全本地运行 · 不上传任何数据</p>

    <div class="share-section">
      <button class="share-btn" onclick="downloadShareCard()">📤 保存分享卡 (PNG)</button>
    </div>

    <canvas id="share-canvas" width="720" height="480"></canvas>
  </div>

  <script>
    // v0.5: 分享卡数据（来自后端）
    window.__SHARE_CARD_DATA__ = {{ share_card_data | safe }};

    function downloadShareCard() {
      const data = window.__SHARE_CARD_DATA__;
      if (!data) { alert('分享卡数据缺失'); return; }
      const canvas = document.getElementById('share-canvas');
      const ctx = canvas.getContext('2d');
      const W = canvas.width, H = canvas.height;

      // 背景渐变
      const grad = ctx.createLinearGradient(0, 0, W, H);
      grad.addColorStop(0, '#1e293b');
      grad.addColorStop(1, '#334155');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      // 标题
      ctx.fillStyle = '#e2e8f0';
      ctx.font = 'bold 28px -apple-system, "Segoe UI", sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(data.title, W / 2, 60);

      // Persona
      ctx.fillStyle = data.persona_color;
      ctx.font = 'bold 64px -apple-system, "Segoe UI", sans-serif';
      ctx.fillText(data.persona, W / 2, 150);

      // Period + total
      ctx.fillStyle = '#94a3b8';
      ctx.font = '18px -apple-system, "Segoe UI", sans-serif';
      ctx.fillText(data.period + ' · 共 ' + data.total_human, W / 2, 195);

      // Top categories as horizontal bars
      const barX = 100, barW = W - 200, barH = 28;
      const startY = 240;
      data.top_categories.forEach((cat, i) => {
        const y = startY + i * (barH + 16);
        const filled = barW * (cat.pct / 100);

        // 背景
        ctx.fillStyle = 'rgba(255, 255, 255, 0.05)';
        ctx.fillRect(barX, y, barW, barH);

        // 填充
        ctx.fillStyle = cat.color;
        ctx.fillRect(barX, y, filled, barH);

        // 类别名
        ctx.fillStyle = '#e2e8f0';
        ctx.font = 'bold 16px -apple-system, "Segoe UI", sans-serif';
        ctx.textAlign = 'left';
        ctx.fillText(cat.icon + ' ' + cat.name, barX + 8, y + 19);

        // 百分比
        ctx.textAlign = 'right';
        ctx.fillText(cat.pct.toFixed(1) + '%  ·  ' + cat.duration_human, barX + barW - 8, y + 19);
      });

      // Highlight insight
      if (data.highlight_insight) {
        ctx.fillStyle = '#fbbf24';
        ctx.font = 'italic 16px -apple-system, "Segoe UI", sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('💡 ' + data.highlight_insight, W / 2, H - 60);
      }

      // Footer
      ctx.fillStyle = '#64748b';
      ctx.font = '13px -apple-system, "Segoe UI", sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(data.footer, W / 2, H - 25);

      // 下载
      const link = document.createElement('a');
      link.download = 'digital-nutrition-' + new Date().toISOString().slice(0, 10) + '.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    }
  </script>

  <script src="assets/echarts.min.js"></script>
  <script>
    const chart = echarts.init(document.getElementById('chart'));
    const option = {
      tooltip: {
        trigger: 'item',
        formatter: '{b}: {c} ({d}%)'
      },
      legend: {
        bottom: 0,
        textStyle: { color: '#e2e8f0' }
      },
      series: [{
        type: 'pie',
        radius: ['40%', '70%'],
        avoidLabelOverlap: false,
        itemStyle: {
          borderRadius: 4,
          borderColor: '#1e293b',
          borderWidth: 2
        },
        label: {
          show: true,
          color: '#e2e8f0',
          formatter: '{b}\n{d}%'
        },
        data: {{ chart_data | safe }}
      }]
    };
    chart.setOption(option);

    {% if daily_chart_data %}
    const dailyChart = echarts.init(document.getElementById('daily-chart'));
    dailyChart.setOption({
      tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
      legend: { bottom: 0, textStyle: { color: '#e2e8f0' } },
      grid: { left: 50, right: 20, top: 30, bottom: 50 },
      xAxis: { type: 'category', data: {{ daily_chart_dates | safe }}, axisLabel: { color: '#e2e8f0' } },
      yAxis: { type: 'value', axisLabel: { color: '#e2e8f0' } },
      series: {{ daily_chart_data | safe }}
    });
    {% endif %}
  </script>
</body>
</html>
